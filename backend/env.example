# Family Hub Backend Environment Variables
# Copy this file to .env and update the values

# Application
APP_NAME=Family Hub
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/family_hub
DATABASE_ECHO=false

# JWT Authentication
# IMPORTANT: Change this in production!
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# External APIs
# Configure your preferred exchange-rate provider if needed.
# The defaults below are placeholders and should be adjusted for your deployment.
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/latest?base={base}
EXCHANGE_RATE_HISTORICAL_API_URL=https://api.exchangerate.host/{date}?base={base}

# Points System
POINTS_EXPIRY_DAYS=90

# Uploads
UPLOAD_DIR=/data/uploads
UPLOAD_PUBLIC_BASE_URL=/uploads
UPLOAD_MAX_BYTES=10485760
